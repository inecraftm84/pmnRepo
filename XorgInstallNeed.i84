install some X11,to run Xorg
make a /etc/X11/xorg.conf.d/10-mouse.conf
type:
Section "InputDevice"
    Identifier "Mouse0"
    Driver "libinput"
    Option "Device" "/dev/input/event1"
EndSection

Section "ServerLayout"
    Identifier "Layout0"
    InputDevice "Mouse0" "CorePointer"
EndSection
